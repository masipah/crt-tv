# crt-tv configuration — read by the weather-kiosk service and the `tv` command.
# Installed to /etc/crt-tv/crt-tv.env (install.sh won't overwrite your edits).

# URL the kiosk shows at boot. Point it at ws4kp (8080) or ws3kp (8083), or
# paste a ws4kp permalink URL (host changed to 127.0.0.1:8080) to bake in your
# location and display settings. No quoting needed — '&' and '?' are fine here.
KIOSK_URL=http://127.0.0.1:8080/

# Optional: separate URL for the retro channel (`tv retro` / the 3000+ button).
# Paste a ws3kp permalink here (host changed to 127.0.0.1:8083) to bake in
# its location; otherwise the retro channel starts unconfigured.
#KIOSK_URL_3000=http://127.0.0.1:8083/

# Extra Chromium flags for the kiosk, space-separated (optional).
#KIOSK_FLAGS=

# `tv play <name>` looks here when <name> isn't an absolute/relative path.
# The web remote's video library also lists this directory.
MEDIA_DIR=/srv/media

# Port for the web remote (http://<pi>:8090/).
CRT_REMOTE_PORT=8090
