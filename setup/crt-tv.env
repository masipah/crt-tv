# crt-tv configuration — read by the weather-kiosk service and the `tv` command.
# Installed to /etc/crt-tv/crt-tv.env (install.sh won't overwrite your edits).

# URL the kiosk shows at boot. Paste a ws4kp permalink URL (host changed to
# 127.0.0.1:8080) to bake in your location and display settings. No quoting
# needed — '&' and '?' are fine here.
KIOSK_URL=http://127.0.0.1:8080/

# Background music (ws4kp's built-in tracks) over the TRRS audio pins.
# Set to off to silence the weather channel.
#KIOSK_MUSIC=on

# Extra Chromium flags for the kiosk, space-separated (optional).
#KIOSK_FLAGS=

# `tv play <name>` looks here when <name> isn't an absolute/relative path.
# The web remote's video library also lists this directory.
MEDIA_DIR=/srv/media

# Port for the web remote (http://<pi>:8090/).
CRT_REMOTE_PORT=8090

# AirPlay buffering, used to shift video for lip-sync while casting.
# Must match raop.latency.ms in /etc/pipewire/pipewire.conf.d/50-crt-tv-airplay.conf.
#AIRPLAY_LATENCY_MS=2000
