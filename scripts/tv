#!/usr/bin/env bash
# tv — control what's showing on the PVM.
set -euo pipefail

RUN_DIR=/run/crt-tv
PLAYLIST=$RUN_DIR/playlist.m3u
KIOSK_ENV=$RUN_DIR/kiosk.env
MPV_SOCK=$RUN_DIR/mpv.sock
ENV_FILE=/etc/crt-tv/crt-tv.env

# Don't source the env file — values like permalink KIOSK_URLs contain '&'
# and other shell metacharacters. Pull out single keys instead.
env_get() {
  { [[ -f $ENV_FILE ]] && sed -n "s/^$1=//p" "$ENV_FILE" | tail -n1 | tr -d '"'; } || true
}
MEDIA_DIR=$(env_get MEDIA_DIR)
MEDIA_DIR=${MEDIA_DIR:-/srv/media}

usage() {
  cat <<'EOF'
usage: tv <command>

  weather            show the WeatherStar 4000+
  play [path]...     play the videos bucket in order (no args), or the given
                     files/folders; a single bucket video continues through
                     the bucket from there. Commercials cut in automatically.
  break [secs]       cut to the weather now, then back to the video (default 120s)
  autostart          (run at boot) show the weather, muted
  pause              toggle pause
  mute               toggle mute (whole TV: weather music and videos)
  shuffle            shuffle the playlist order
  next | prev        skip within the playlist
  stop               blank the screen (stop player and kiosk)
  status             show what's running
  doctor             one-shot diagnostic dump (paste this when asking for help)
  reboot             reboot the Pi
EOF
}

ARGS=("$@")
as_root() {
  if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "${ARGS[@]}"
  fi
  mkdir -p "$RUN_DIR"
}

mpv_cmd() {
  printf '%s\n' "$1" | socat - "UNIX-CONNECT:$MPV_SOCK" >/dev/null || {
    echo "tv: player not running (start one with: tv play <path>)" >&2
    exit 1
  }
}

mpv_get() {
  { printf '{"command":["get_property","%s"]}\n' "$1" |
    socat - "UNIX-CONNECT:$MPV_SOCK" 2>/dev/null |
    sed -nE 's/.*"data":(true|false|[0-9][0-9.]*).*/\1/p' | head -n1; } || true
}

# One hardware mute for the whole TV: the weather music (chromium) and the
# videos (mpv) come out of the same jack, so mute at the ALSA mixer.
mixer() {
  amixer -q sset Headphone "$@" 2>/dev/null ||
    amixer -q sset PCM "$@" 2>/dev/null || true
}

# A pending weather break must not outlive a manual mode change
cancel_break() {
  systemctl stop crt-weatherbreak.timer 2>/dev/null || true
  systemctl stop crt-weatherbreak.service 2>/dev/null || true
  rm -f "$RUN_DIR/resume"
}

# All playable files under <dir>, in the library's persistent play order
# (.playorder.m3u, maintained by the web remote) when available; plain
# alphabetical otherwise.
find_media() { # <dir>
  local dir lib m3u f matched=0
  dir=$(realpath "$1")
  lib=$(realpath "$MEDIA_DIR" 2>/dev/null) || lib=""
  m3u="$lib/.playorder.m3u"
  if [[ -n $lib && -f $m3u && ($dir == "$lib" || $dir == "$lib"/*) ]]; then
    while IFS= read -r f; do
      if [[ $f == "$dir"/* && -f $f ]]; then
        printf '%s\n' "$f"
        matched=1
      fi
    done <"$m3u"
    [[ $matched -eq 1 ]] && return 0
  fi
  find "$dir" -type f \( \
    -iname '*.mp4' -o -iname '*.mkv' -o -iname '*.avi' -o \
    -iname '*.mov' -o -iname '*.m4v' -o -iname '*.mpg' -o \
    -iname '*.mpeg' -o -iname '*.ts' -o -iname '*.webm' \) | sort
}

cmd=${1:-status}
[[ $# -gt 0 ]] && shift

case $cmd in
  weather | 4000)
    as_root
    cancel_break
    # Keep the configured URL (e.g. a permalink with baked-in location) when
    # it already points at ws4kp; only fall back to the bare default otherwise.
    url=$(env_get KIOSK_URL)
    [[ $url == *:8080* ]] || url=http://127.0.0.1:8080/
    printf 'KIOSK_URL=%s\n' "$url" >"$KIOSK_ENV"
    systemctl restart weather-kiosk.service
    ;;
  play)
    as_root
    # No arguments: play the whole videos bucket, in library order
    if [[ $# -eq 0 ]]; then
      set -- "$MEDIA_DIR/videos"
    fi
    tmp=$(mktemp)
    for p in "$@"; do
      # Bare names resolve against MEDIA_DIR
      if [[ ! -e $p && -n ${MEDIA_DIR:-} && -e $MEDIA_DIR/$p ]]; then
        p=$MEDIA_DIR/$p
      fi
      if [[ -d $p ]]; then
        find_media "$p" >>"$tmp"
      elif [[ -f $p ]]; then
        realpath "$p" >>"$tmp"
      else
        echo "tv: not found: $p" >&2
        rm -f "$tmp"
        exit 1
      fi
    done
    if [[ ! -s $tmp ]]; then
      echo "tv: no playable files found" >&2
      rm -f "$tmp"
      exit 1
    fi
    # A single bucket video plays like a channel: continue through the whole
    # videos bucket from that point (a multi-path list — e.g. the web queue —
    # plays exactly as given).
    if [[ $# -eq 1 && $(wc -l <"$tmp") -eq 1 ]]; then
      only=$(<"$tmp")
      lib_root=$(realpath "$MEDIA_DIR/videos" 2>/dev/null || true)
      if [[ -n $lib_root && $only == "$lib_root"/* ]]; then
        find_media "$lib_root" | awk -v start="$only" '
          { a[NR] = $0; if ($0 == start) s = NR }
          END {
            if (!s) s = 1
            for (i = s; i <= NR; i++) print a[i]
            for (i = 1; i < s; i++) print a[i]
          }' >"$tmp"
      fi
    fi
    cancel_break
    install -m 644 "$tmp" "$PLAYLIST"
    rm -f "$tmp"
    systemctl restart crt-player.service
    ;;
  break | weatherbreak)
    as_root
    secs=${1:-120}
    if ! systemctl -q is-active crt-player.service; then
      echo "tv: no video playing — switching to weather instead" >&2
      exec "$0" weather
    fi
    cancel_break
    pos=$(mpv_get playlist-pos)
    time_pos=$(mpv_get time-pos)
    printf '%s %s\n' "${pos:-0}" "${time_pos:-0}" >"$RUN_DIR/resume"
    systemd-run --quiet --collect --unit=crt-weatherbreak \
      --on-active="${secs}s" --timer-property=AccuracySec=1s \
      /usr/local/bin/tv resume
    # Timer first, switch queued last with --no-block: when mpv's auto-break
    # script calls us, stopping the player kills this very process — make
    # sure everything is scheduled before that happens.
    systemctl --no-block restart weather-kiosk.service
    echo "weather for ${secs}s, then back to the video"
    ;;
  resume)
    as_root
    # Fired by the crt-weatherbreak timer; play-media-x.sh consumes the
    # resume file and picks up where the video left off
    systemctl restart crt-player.service
    ;;
  autostart)
    as_root
    # Boot default (crt-autostart.service): the kiosk unit brings up the
    # weather on its own; just make sure the whole TV starts silent. Take
    # control from the web remote (unmute, play videos) when wanted.
    mixer mute
    ;;
  pause)
    as_root
    mpv_cmd 'cycle pause'
    ;;
  mute)
    as_root
    mixer toggle
    ;;
  shuffle)
    as_root
    mpv_cmd 'playlist-shuffle'
    ;;
  next)
    as_root
    mpv_cmd 'playlist-next'
    ;;
  prev)
    as_root
    mpv_cmd 'playlist-prev'
    ;;
  stop)
    as_root
    cancel_break
    systemctl stop crt-player.service weather-kiosk.service
    ;;
  status)
    for u in ws4kp weather-kiosk crt-player; do
      printf '%-15s %s\n' "$u" "$(systemctl is-active "$u.service" 2>/dev/null || true)"
    done
    ;;
  doctor)
    as_root
    echo "== units =="
    for u in ws4kp weather-kiosk crt-player crt-remote; do
      printf '%-15s active=%-10s enabled=%s\n' "$u" \
        "$(systemctl is-active "$u.service" 2>/dev/null || true)" \
        "$(systemctl is-enabled "$u.service" 2>/dev/null || true)"
    done
    echo
    echo "== web servers =="
    for p in 8080 8090; do
      printf ':%-5s http %s\n' "$p" \
        "$(curl -fsS -o /dev/null -w '%{http_code}' --max-time 3 "http://127.0.0.1:$p/" 2>/dev/null || echo unreachable)"
    done
    echo
    echo "== sessions =="
    loginctl list-sessions --no-legend 2>/dev/null || true
    echo
    echo "== display =="
    ls /sys/class/drm/ 2>/dev/null || true
    for c in /sys/class/drm/card*-Composite-1; do
      [[ -e $c ]] || continue
      echo "$c: status=$(cat "$c/status" 2>/dev/null) modes: $(tr '\n' ' ' <"$c/modes" 2>/dev/null)"
    done
    echo
    echo "== audio =="
    amixer sget Headphone 2>/dev/null || amixer sget PCM 2>/dev/null || echo "(no mixer control found)"
    echo
    echo "== boot config =="
    grep -E 'vc4|tvout|sdtv' /boot/firmware/config.txt 2>/dev/null || true
    cat /boot/firmware/cmdline.txt 2>/dev/null || true
    echo
    echo "== versions =="
    node --version 2>/dev/null || echo "node: missing"
    command -v chromium chromium-browser cage mpv 2>/dev/null || true
    echo
    echo "== mpv log =="
    tail -n 60 /run/crt-tv/mpv.log 2>/dev/null || echo "(no mpv log this boot)"
    echo
    echo "== recent logs =="
    for u in ws4kp weather-kiosk crt-player crt-remote; do
      # extra lines for the player: mpv's vo errors scroll past quickly
      n=15
      [[ $u == crt-player ]] && n=50
      echo "--- $u"
      journalctl -u "$u.service" -b --no-pager -n "$n" 2>/dev/null || true
    done
    ;;
  reboot)
    as_root
    systemctl reboot
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
