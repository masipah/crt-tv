#!/usr/bin/env bash
# tv — control what's showing on the PVM.
set -euo pipefail

RUN_DIR=/run/crt-tv
PLAYLIST=$RUN_DIR/playlist.m3u
KIOSK_ENV=$RUN_DIR/kiosk.env
MPV_SOCK=$RUN_DIR/mpv.sock
ENV_FILE=/etc/crt-tv/crt-tv.env

# Don't source the env file — values like permalink KIOSK_URLs contain '&'
# and other shell metacharacters. Pull out single keys instead.
env_get() {
  { [[ -f $ENV_FILE ]] && sed -n "s/^$1=//p" "$ENV_FILE" | tail -n1 | tr -d '"'; } || true
}
MEDIA_DIR=$(env_get MEDIA_DIR)
MEDIA_DIR=${MEDIA_DIR:-/srv/media}

usage() {
  cat <<'EOF'
usage: tv <command>

  weather            show the WeatherStar 4000+
  play [path]...     play the videos bucket in order (no args), or the given
                     files/folders; a single bucket video continues through
                     the bucket from there. Commercials cut in automatically.
  break [secs]       cut to the weather now, then back to the video (default 120s)
  autostart          (run at boot) show the weather, muted
  pause              toggle pause
  mute               toggle mute (whole TV: weather music and videos)
  airplay            toggle audio output: AirPlay speakers <-> TV jack
  volume [0-100]     show or set the volume of the active output
  normalize          reset output levels (jack 50%, AirPlay 10%)
  shuffle            toggle shuffled playback (videos only)
  commercials        toggle whether commercials play (on by default)
  next | prev        skip within the playlist
  stop               blank the screen (stop player and kiosk)
  status             show what's running
  doctor             one-shot diagnostic dump (paste this when asking for help)
  reboot             reboot the Pi
EOF
}

ARGS=("$@")
as_root() {
  if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "${ARGS[@]}"
  fi
  mkdir -p "$RUN_DIR"
}

mpv_cmd() {
  printf '%s\n' "$1" | socat - "UNIX-CONNECT:$MPV_SOCK" >/dev/null || {
    echo "tv: player not running (start one with: tv play <path>)" >&2
    exit 1
  }
}

# Fire-and-forget mpv command: fine if the player isn't running
mpv_try() {
  printf '%s\n' "$1" | socat - "UNIX-CONNECT:$MPV_SOCK" >/dev/null 2>&1 || true
}

mpv_get() {
  { printf '{"command":["get_property","%s"]}\n' "$1" |
    socat - "UNIX-CONNECT:$MPV_SOCK" 2>/dev/null |
    sed -nE 's/.*"data":(true|false|[0-9][0-9.]*).*/\1/p' | head -n1; } || true
}

# PipeWire control as the crt user (whose session owns the audio graph)
wp() {
  local uid
  uid=$(id -u crt 2>/dev/null) || return 1
  sudo -u crt XDG_RUNTIME_DIR="/run/user/$uid" wpctl "$@" 2>/dev/null
}

# Sink ids from wpctl status; inspect each to find the right backend
wp_sink_ids() {
  wp status | awk '/Sinks:/ { f = 1; next } /(Sources|Filters|Streams):/ { f = 0 } f' |
    sed -nE 's/^[^0-9]*([0-9]+)\..*/\1/p'
}

wp_find_sink() { # <pattern matched against wpctl inspect output>
  local id
  for id in $(wp_sink_ids); do
    if wp inspect "$id" | grep -qi "$1"; then
      echo "$id"
      return 0
    fi
  done
  return 1
}

# The current default sink (the '*' row in wpctl status), if any
wp_default_sink_id() {
  wp status | awk '/Sinks:/ { f = 1; next } /(Sources|Filters|Streams):/ { f = 0 } f' |
    grep -F '*' | sed -nE 's/^[^0-9]*([0-9]+)\..*/\1/p' | head -n1
}

# Level the outputs, volumes only — mute state is left alone. The jack
# starts at a 50% default (headroom on the slider; the PVM's own knob is
# the last stage); AirPlay sinks are parked at a safe 10% because they
# usually feed amplified speakers. Once the user has set a volume
# ($RUN_DIR/volume-set — written by tv volume and the web slider), the
# default sink is theirs and stays untouched; late-appearing sinks still
# get parked at the defaults.
normalize_outputs() {
  local id skip=""
  if [[ -f $RUN_DIR/volume-set ]]; then
    skip=$(wp_default_sink_id) || true
  fi
  for id in $(wp_sink_ids); do
    if [[ $id == "$skip" ]]; then
      continue
    fi
    if wp inspect "$id" | grep -qi raop; then
      wp set-volume "$id" 0.10 || true
    else
      wp set-volume "$id" 0.50 || true
    fi
  done
  # hardware stage pinned at 100%, addressed by card — pipewire-alsa
  # redirects the default ALSA control, so plain amixer misses the chip.
  # VOLUME ONLY — no unmute here; that word once snuck in and had every
  # boot sweep un-muting the speaker right after mixer mute set it.
  amixer -q -c Headphones sset PCM 100% 2>/dev/null ||
    amixer -q sset Headphone 100% 2>/dev/null ||
    amixer -q sset PCM 100% 2>/dev/null || true
}

# One mute for the whole TV, applied to EVERY output at once — a muted TV
# stays silent no matter which output becomes default later, and unmuting
# brings back whichever is active. State is read from the default sink.
# (No amixer here: pipewire-alsa redirects the default ALSA control, so
# hardware-level mutes stopped being reliable — PipeWire owns the graph.)
mixer() {
  local id state
  case $1 in
    toggle)
      # the flag is the intent of record — enforced by the web remote's
      # server every few seconds until unmute, so nothing (wireplumber
      # route churn, late sinks) can un-mute the TV behind our backs
      if [[ -f $RUN_DIR/muted ]]; then
        mixer unmute
      else
        mixer mute
      fi
      ;;
    mute | unmute)
      state=1
      amixer_arg=mute
      if [[ $1 == unmute ]]; then
        state=0
        amixer_arg=unmute
        rm -f "$RUN_DIR/muted"
      else
        : >"$RUN_DIR/muted"
      fi
      for id in $(wp_sink_ids); do
        wp set-mute "$id" "$state" || true
      done
      # hardware layer too (card-addressed — pipewire-alsa hides the chip
      # from the default control): wireplumber re-applies unmuted route
      # defaults when a route activates, but it can't touch a hardware mute
      amixer -q -c Headphones sset PCM "$amixer_arg" 2>/dev/null ||
        amixer -q sset Headphone "$amixer_arg" 2>/dev/null ||
        amixer -q sset PCM "$amixer_arg" 2>/dev/null || true
      # landing level: until the user has picked a volume, unmuting always
      # comes up at the defaults (jack 50%, AirPlay 10%) — never a blast,
      # and the web slider shows exactly what's playing
      if [[ $1 == unmute && ! -f $RUN_DIR/volume-set ]]; then
        normalize_outputs
      fi
      ;;
  esac
}

# A pending weather break must not outlive a manual mode change
cancel_break() {
  systemctl stop crt-weatherbreak.timer 2>/dev/null || true
  systemctl stop crt-weatherbreak.service 2>/dev/null || true
  rm -f "$RUN_DIR/resume"
}

# All playable files under <dir>, in the library's persistent play order
# (.playorder.m3u, maintained by the web remote) when available; plain
# alphabetical otherwise.
find_media() { # <dir>
  local dir lib m3u f matched=0
  dir=$(realpath "$1")
  lib=$(realpath "$MEDIA_DIR" 2>/dev/null) || lib=""
  m3u="$lib/.playorder.m3u"
  if [[ -n $lib && -f $m3u && ($dir == "$lib" || $dir == "$lib"/*) ]]; then
    while IFS= read -r f; do
      if [[ $f == "$dir"/* && -f $f ]]; then
        printf '%s\n' "$f"
        matched=1
      fi
    done <"$m3u"
    [[ $matched -eq 1 ]] && return 0
  fi
  find "$dir" -type f \( \
    -iname '*.mp4' -o -iname '*.mkv' -o -iname '*.avi' -o \
    -iname '*.mov' -o -iname '*.m4v' -o -iname '*.mpg' -o \
    -iname '*.mpeg' -o -iname '*.ts' -o -iname '*.webm' \) | sort
}

cmd=${1:-status}
[[ $# -gt 0 ]] && shift

case $cmd in
  weather | 4000)
    as_root
    cancel_break
    # Keep the configured URL (e.g. a permalink with baked-in location) when
    # it already points at ws4kp; only fall back to the bare default otherwise.
    url=$(env_get KIOSK_URL)
    [[ $url == *:8080* ]] || url=http://127.0.0.1:8080/
    printf 'KIOSK_URL=%s\n' "$url" >"$KIOSK_ENV"
    systemctl restart weather-kiosk.service
    ;;
  play)
    as_root
    # No arguments: play the whole videos bucket, in library order
    if [[ $# -eq 0 ]]; then
      set -- "$MEDIA_DIR/videos"
    fi
    tmp=$(mktemp)
    for p in "$@"; do
      # Bare names resolve against MEDIA_DIR
      if [[ ! -e $p && -n ${MEDIA_DIR:-} && -e $MEDIA_DIR/$p ]]; then
        p=$MEDIA_DIR/$p
      fi
      if [[ -d $p ]]; then
        find_media "$p" >>"$tmp"
      elif [[ -f $p ]]; then
        realpath "$p" >>"$tmp"
      else
        echo "tv: not found: $p" >&2
        rm -f "$tmp"
        exit 1
      fi
    done
    if [[ ! -s $tmp ]]; then
      echo "tv: no playable files found" >&2
      rm -f "$tmp"
      exit 1
    fi
    # A single bucket video plays like a channel: continue through the whole
    # videos bucket from that point (a multi-path list — e.g. the web queue —
    # plays exactly as given).
    selected=0
    if [[ $# -eq 1 && $(wc -l <"$tmp") -eq 1 ]]; then
      only=$(<"$tmp")
      lib_root=$(realpath "$MEDIA_DIR/videos" 2>/dev/null || true)
      if [[ -n $lib_root && $only == "$lib_root"/* ]]; then
        selected=1
        find_media "$lib_root" | awk -v start="$only" '
          { a[NR] = $0; if ($0 == start) s = NR }
          END {
            if (!s) s = 1
            for (i = s; i <= NR; i++) print a[i]
            for (i = 1; i < s; i++) print a[i]
          }' >"$tmp"
      fi
    fi
    # Shuffle mode is baked into the playlist here — never via mpv's
    # --shuffle, which would scramble away the video the user just picked.
    # A picked video stays first; whole-bucket plays shuffle fully;
    # explicit lists (the queue) are literal and stay untouched.
    if [[ -f $RUN_DIR/shuffle ]]; then
      if [[ $selected -eq 1 ]]; then
        { head -n 1 "$tmp"; tail -n +2 "$tmp" | shuf; } >"$tmp.s"
        mv "$tmp.s" "$tmp"
      elif [[ $# -eq 1 && -d ${1:-/nonexistent} ]]; then
        shuf "$tmp" >"$tmp.s"
        mv "$tmp.s" "$tmp"
      fi
    fi
    cancel_break
    install -m 644 "$tmp" "$PLAYLIST"
    rm -f "$tmp"
    systemctl restart crt-player.service
    ;;
  break | weatherbreak)
    as_root
    secs=${1:-120}
    if ! systemctl -q is-active crt-player.service; then
      echo "tv: no video playing — switching to weather instead" >&2
      exec "$0" weather
    fi
    cancel_break
    pos=$(mpv_get playlist-pos)
    time_pos=$(mpv_get time-pos)
    printf '%s %s\n' "${pos:-0}" "${time_pos:-0}" >"$RUN_DIR/resume"
    systemd-run --quiet --collect --unit=crt-weatherbreak \
      --on-active="${secs}s" --timer-property=AccuracySec=1s \
      /usr/local/bin/tv resume
    # Timer first, switch queued last with --no-block: when mpv's auto-break
    # script calls us, stopping the player kills this very process — make
    # sure everything is scheduled before that happens.
    systemctl --no-block restart weather-kiosk.service
    echo "weather for ${secs}s, then back to the video"
    ;;
  bridge)
    as_root
    # internal: feeder for the OwnTone metadata bridge (started when the
    # "(with titles)" output is selected, stopped when leaving it)
    case ${1:-} in
      start) systemctl start crt-bridge.service ;;
      stop) systemctl stop crt-bridge.service 2>/dev/null || true ;;
      *) echo "usage: tv bridge start|stop" >&2; exit 1 ;;
    esac
    ;;
  resume)
    as_root
    # Fired by the crt-weatherbreak timer; play-media-x.sh consumes the
    # resume file and picks up where the video left off
    systemctl restart crt-player.service
    ;;
  autostart)
    as_root
    # Boot default (crt-autostart.service): the kiosk unit brings up the
    # weather on its own; start silent with every output at its default
    # level (jack 50%, AirPlay 10%) so unmuting is never a blast. Take
    # control from the web remote (unmute, play videos) when wanted.
    # Order matters: pin the default to the TV jack FIRST (retrying while
    # PipeWire comes up), then mute — muting before the pin can land on a
    # remembered AirPlay default and leave the jack live. The jack pin also
    # stops wireplumber restoring an AirPlay default when it reappears.
    for _ in 1 2 3 4 5; do
      if id=$(wp_find_sink 'api\.alsa'); then
        wp set-default "$id" || true
        break
      fi
      sleep 3
    done
    # keep sweeping for a minute: AirPlay sinks appear late (mDNS), and
    # wireplumber re-applies unmuted route defaults when the jack's route
    # activates with the first stream (~20s in, when the weather music
    # starts). Mute always goes LAST so nothing in the sweep can undo it.
    normalize_outputs
    mixer mute
    for _ in $(seq 1 12); do
      sleep 5
      normalize_outputs
      # enforce the intent flag, don't re-assert it: an unmute from the web
      # remote during this window removes the flag, and that must win — the
      # sweep only re-mutes while the boot mute is still the standing intent
      if [[ -f $RUN_DIR/muted ]]; then
        mixer mute
      fi
    done
    # boot messages keep accumulating on the hidden console after the
    # kiosk's own clear; wipe the VT buffer once everything has settled so
    # the first weather->video switch reveals black, not a flash of text
    /usr/local/lib/crt-tv/clear-console.sh 2>/dev/null || true
    ;;
  normalize)
    as_root
    # an explicit reset: the user's volume choice yields to the defaults
    rm -f "$RUN_DIR/volume-set"
    normalize_outputs
    echo "outputs reset: jack 50%, AirPlay 10%"
    ;;
  pause)
    as_root
    mpv_cmd 'cycle pause'
    ;;
  mute)
    as_root
    mixer toggle
    ;;
  volume)
    as_root
    if [[ -n ${1:-} ]]; then
      if ! [[ $1 =~ ^[0-9]+$ ]] || (($1 > 100)); then
        echo "tv: volume must be 0-100" >&2
        exit 1
      fi
      v=$(awk "BEGIN { printf \"%.2f\", $1 / 100 }")
      wp set-volume @DEFAULT_AUDIO_SINK@ "$v" ||
        amixer -q sset Headphone "${1}%" 2>/dev/null ||
        amixer -q sset PCM "${1}%" 2>/dev/null || true
      # record the choice — the boot sweep stops leveling the default
      # sink once a volume has been set on purpose (see normalize_outputs)
      : >"$RUN_DIR/volume-set"
      echo "volume: ${1}%"
    else
      wp get-volume @DEFAULT_AUDIO_SINK@ ||
        amixer sget Headphone 2>/dev/null ||
        amixer sget PCM 2>/dev/null || true
    fi
    ;;
  airplay)
    as_root
    # Toggle the default output between the AirPlay receiver and the jack.
    # PipeWire moves running streams over live — no restart needed. A
    # running video gets its audio-delay adjusted to match the AirPlay
    # buffer so lip-sync holds (see AIRPLAY_LATENCY_MS in crt-tv.env).
    ap_ms=$(env_get AIRPLAY_LATENCY_MS)
    ap_sec=$(awk "BEGIN { printf \"%.3f\", ${ap_ms:-0} / 1000 }")
    if wp inspect @DEFAULT_AUDIO_SINK@ | grep -qi raop; then
      id=$(wp_find_sink 'api\.alsa') || {
        echo "tv: no jack sink found" >&2
        exit 1
      }
      wp set-default "$id"
      mpv_try 'set audio-delay 0'
      echo "audio: TV jack"
    else
      id=$(wp_find_sink 'raop') || {
        echo "tv: no AirPlay device found — is it on and on this network?" >&2
        exit 1
      }
      # engage AirPlay gently: amplified speakers start at 10%; re-assert
      # after activation because wireplumber restores its remembered
      # device volume and can race the first set. Choosing a speaker
      # means wanting to hear it — unmute.
      wp set-volume "$id" 0.10 || true
      wp set-default "$id"
      mpv_try "set audio-delay -$ap_sec"
      sleep 1
      wp set-volume "$id" 0.10 || true
      mixer unmute
      echo "audio: AirPlay (volume starts at 10%)"
    fi
    ;;
  shuffle)
    as_root
    # A mode, not a one-shot: the flag survives channel switches and new
    # plays (play-media-x.sh adds --shuffle) until toggled off or reboot
    if [[ -f $RUN_DIR/shuffle ]]; then
      rm -f "$RUN_DIR/shuffle"
      mpv_try 'playlist-unshuffle'
      echo "shuffle: OFF"
    else
      : >"$RUN_DIR/shuffle"
      mpv_try 'playlist-shuffle'
      echo "shuffle: ON"
    fi
    ;;
  commercials)
    as_root
    # The Lua script in mpv checks this flag at every injection point,
    # so the change applies live — no player restart needed
    if [[ -f $RUN_DIR/no-commercials ]]; then
      rm -f "$RUN_DIR/no-commercials"
      echo "commercials: ON (one random spot after every 4 videos)"
    else
      : >"$RUN_DIR/no-commercials"
      echo "commercials: OFF"
    fi
    ;;
  next)
    as_root
    mpv_cmd 'playlist-next'
    ;;
  prev)
    as_root
    mpv_cmd 'playlist-prev'
    ;;
  stop)
    as_root
    cancel_break
    systemctl stop crt-player.service weather-kiosk.service
    ;;
  status)
    for u in ws4kp weather-kiosk crt-player; do
      printf '%-15s %s\n' "$u" "$(systemctl is-active "$u.service" 2>/dev/null || true)"
    done
    ;;
  doctor)
    as_root
    echo "== units =="
    for u in ws4kp weather-kiosk crt-player crt-remote crt-autostart crt-splash owntone crt-bridge; do
      printf '%-15s active=%-10s enabled=%s\n' "$u" \
        "$(systemctl is-active "$u.service" 2>/dev/null || true)" \
        "$(systemctl is-enabled "$u.service" 2>/dev/null || true)"
    done
    echo
    echo "== web servers =="
    for p in 8080 8090; do
      printf ':%-5s http %s\n' "$p" \
        "$(curl -fsS -o /dev/null -w '%{http_code}' --max-time 3 "http://127.0.0.1:$p/" 2>/dev/null || echo unreachable)"
    done
    echo
    echo "== sessions =="
    loginctl list-sessions --no-legend 2>/dev/null || true
    echo
    echo "== display =="
    ls /sys/class/drm/ 2>/dev/null || true
    for c in /sys/class/drm/card*-Composite-1; do
      [[ -e $c ]] || continue
      echo "$c: status=$(cat "$c/status" 2>/dev/null) modes: $(tr '\n' ' ' <"$c/modes" 2>/dev/null)"
    done
    echo
    echo "== audio =="
    amixer -c Headphones sget PCM 2>/dev/null || amixer sget Headphone 2>/dev/null ||
      amixer sget PCM 2>/dev/null || echo "(no mixer control found)"
    echo "-- pipewire sinks (* = default):"
    wp status 2>/dev/null | awk '/Sinks:/ { f = 1 } /(Sources|Filters):/ { f = 0 } f' || echo "(pipewire not running)"
    echo "-- pipewire streams (who is actually in the graph):"
    wp status 2>/dev/null | sed -n '/Streams:/,/^$/p' || true
    echo "-- owntone outputs:"
    curl -fsS --max-time 3 http://127.0.0.1:3689/api/outputs 2>/dev/null | head -c 500 || echo "(owntone not reachable)"
    echo
    echo "-- pipewire/raop log (user services, this boot):"
    journalctl _UID="$(id -u crt 2>/dev/null || echo 1001)" -b --no-pager -n 400 2>/dev/null |
      grep -iE 'raop|rtsp|wireplumber.*(default|sink)|pipewire.*(error|fail)' | tail -40 || true
    echo
    echo "== boot config =="
    grep -E 'vc4|tvout|sdtv' /boot/firmware/config.txt 2>/dev/null || true
    cat /boot/firmware/cmdline.txt 2>/dev/null || true
    echo
    echo "== versions =="
    node --version 2>/dev/null || echo "node: missing"
    pipewire --version 2>/dev/null | tail -1 || true
    command -v chromium chromium-browser cage mpv 2>/dev/null || true
    echo
    echo "== mpv log =="
    tail -n 60 /run/crt-tv/mpv.log 2>/dev/null || echo "(no mpv log this boot)"
    echo
    echo "== recent logs =="
    for u in ws4kp weather-kiosk crt-player crt-remote crt-autostart; do
      # extra lines for the player: mpv's vo errors scroll past quickly
      n=15
      [[ $u == crt-player ]] && n=50
      echo "--- $u"
      journalctl -u "$u.service" -b --no-pager -n "$n" 2>/dev/null || true
    done
    ;;
  reboot)
    as_root
    systemctl reboot
    ;;
  help | -h | --help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
