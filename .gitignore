# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Local config & secrets
config.toml
.env

# Persisted runtime state (UI-set weather location, etc.)
data/

# Media (videos are large; keep the folder, ignore contents)
media/*
!media/.gitkeep

# Third-party weather assets (fetched by web/display/assets/fetch-assets.sh)
web/display/assets/fonts/
web/display/assets/icons/
# Background music (fetched by fetch-audio.sh; copyrighted, opt-in)
web/display/assets/audio/

# OS
.DS_Store
